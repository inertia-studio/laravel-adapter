{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "inertia-studio/laravel",
    "description": "Server-driven admin panels for Laravel + Inertia.js. Define forms, tables, and pages in PHP — render with React, Vue, or Svelte.",
    "keywords": ["laravel", "inertia", "admin", "panel", "crud", "react", "vue", "svelte"],
    "type": "library",
    "license": "MIT",
    "homepage": "https://inertia-studio.github.io",
    "authors": [
        {
            "name": "Abdullah Khan",
            "email": "abdullah@mantiq.dev"
        }
    ],
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0||^13.0",
        "inertiajs/inertia-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "InertiaStudio\\": "core/",
            "InertiaStudio\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "InertiaStudio\\Laravel\\InertiaStudioServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
